# Environment variables for AIB forecasting bot
# Copy this to .env.local and fill in your actual values
# .env.local is gitignored and will override these values

# === Required ===
METACULUS_TOKEN=

# === Search APIs (optional but recommended) ===
EXA_API_KEY=
EXA_ADMIN_KEY=
ASKNEWS_API_KEY=

# === Financial Data APIs (optional) ===
FRED_API_KEY=
BLS_API_KEY=
CENSUS_API_KEY=

# === Social Media APIs (optional) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# === LLM Routing (optional) ===
# Set to route Claude Code through OpenRouter
OPENROUTER_API_KEY=

# === Model APIs (optional, for external libraries) ===
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# === AIB-specific settings (all optional, have defaults) ===
# AIB_MODEL=claude-opus-4-5-20251101
# AIB_MAX_BUDGET_USD=
# AIB_MAX_TURNS=
