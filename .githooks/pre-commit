#!/usr/bin/env bash
#
# A commit is either data (`notes/` only) or code (no `notes/`). Never both.
#
# Data commits land on main; code commits go through a worktree and a PR. A
# commit that mixes them belongs to neither flow and drags forecast output into
# code review.
#
# Bypass with `git commit --no-verify`.

set -euo pipefail

# A merge legitimately spans both trees.
git_dir="$(git rev-parse --git-dir)"
[ -e "${git_dir}/MERGE_HEAD" ] && exit 0

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACMRD)
[ "${#staged[@]}" -eq 0 ] && exit 0

data=()
code=()
for path in "${staged[@]}"; do
	case "$path" in
	notes/*) data+=("$path") ;;
	*) code+=("$path") ;;
	esac
done

if [ "${#data[@]}" -gt 0 ] && [ "${#code[@]}" -gt 0 ]; then
	cat >&2 <<-EOF

		  ✘ commit blocked: this mixes ${#data[@]} data file(s) with ${#code[@]} code file(s).

		    Data (notes/) is committed to main; code goes through a worktree and a PR.
		    Split them:

		        git reset
		        git add notes/ && git commit -m 'data(forecasts): …'
		        git add <code paths> && git commit -m 'feat(scope): …'

		    Data:
	EOF

	printf '        %s\n' "${data[@]:0:3}" >&2
	[ "${#data[@]}" -gt 3 ] && printf '        … and %s more\n' "$((${#data[@]} - 3))" >&2

	printf '\n    Code:\n' >&2
	printf '        %s\n' "${code[@]:0:3}" >&2
	[ "${#code[@]}" -gt 3 ] && printf '        … and %s more\n' "$((${#code[@]} - 3))" >&2

	printf '\n' >&2
	exit 1
fi

exit 0
